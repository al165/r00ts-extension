{
    "compilerOptions": {
        "target": "es2022",
        "module": "nodenext",
        "types": [
            "node",
            "webextension-polyfill"
        ],
        "strict": true,
        "skipLibCheck": true,
        "outDir": "./dist",
        "rootDir": "./src",
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}
