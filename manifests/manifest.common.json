{
    "manifest_version": 3,
    "name": "r00ts",
    "description": "r00ts connects you to the datacenters that serve your everyday internet",
    "version": "0.1",
    "action": {
        "default_popup": "popup/index.html"
    },
    "permissions": [
        "tabs",
        "storage",
        "webRequest"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
